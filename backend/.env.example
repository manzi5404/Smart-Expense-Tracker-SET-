# Smart Expense Tracker Backend Environment Variables

# === PRODUCTION (Railway + Render) ===
# Option A: Use DATABASE_URL (recommended for Railway)
# DATABASE_URL=mysql://user:password@host:port/database
NODE_ENV=production
PORT=5000

# Option B: Individual database variables (if DATABASE_URL not used)
DB_HOST=your-railway-host.internal
DB_PORT=3306
DB_NAME=smartExpenseTracker
DB_USER=root
DB_PASSWORD=your-db-password

# JWT (generate a strong secret for production)
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# CORS (your production frontend domain)
CORS_ORIGIN=https://your-frontend.vercel.app

# Resend (Password Reset emails)
RESEND_API_KEY=re_your_resend_api_key

# === LOCAL DEVELOPMENT ===
# NODE_ENV=development
# PORT=5000
# DB_HOST=localhost
# DB_PORT=3306
# DB_NAME=smartExpenseTracker
# DB_USER=root
# DB_PASSWORD=
# CORS_ORIGIN=http://localhost:5173

