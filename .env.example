# Smart Expense Tracker Frontend Environment Variables

# === PRODUCTION (Set in Vercel/Netlify dashboard) ===
# Your production backend URL (without /api suffix - it's added automatically)
VITE_API_URL=https://your-backend.onrender.com

# === LOCAL DEVELOPMENT ===
# VITE_API_URL=http://localhost:5173

# === EMAILJS CONFIGURATION ===
# EmailJS service ID (from EmailJS dashboard)
VITE_EMAILJS_SERVICE_ID=your_service_id

# EmailJS template ID (from EmailJS dashboard)
VITE_EMAILJS_TEMPLATE_ID=your_template_id

# EmailJS public key (from EmailJS dashboard)
VITE_EMAILJS_PUBLIC_KEY=your_public_key
